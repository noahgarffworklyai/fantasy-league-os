# LAN IP of your Mac — used by the app to call the API (not for sharing invites).
EXPO_PUBLIC_API_URL=http://192.168.1.1:3000

# Treasury testing: no Stripe keys needed on mobile. On the API, leave STRIPE_SECRET_KEY
# empty in apps/api/.env — payments complete instantly in dev mode (no real money).

# Optional public URL for web invite pages in production, e.g. https://app.fantasyleagueos.com
# Leave unset during local dev — the app shares a join code instead of localhost links.
# EXPO_PUBLIC_INVITE_WEB_URL=https://app.example.com
