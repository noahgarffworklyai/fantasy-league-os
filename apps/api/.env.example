DATABASE_URL=postgresql://flos:flos@localhost:5432/fantasy_league_os
REDIS_URL=redis://localhost:6379
PORT=3000
HOST=0.0.0.0
JWT_SECRET=dev-jwt-secret-change-in-production
CREDENTIALS_ENCRYPTION_KEY=dev-key-change-in-production-32b
# Payments
# ─────────────────────────────────────────────────────────────────────────────
# Mode A — Dev (no Stripe): leave STRIPE_SECRET_KEY empty. Buy-ins complete instantly.
#
# Mode B — Stripe test cards + webhooks (no Homebrew; CLI auto-downloads on first pnpm stripe:listen)
#   1. Set STRIPE_SECRET_KEY=sk_test_... from https://dashboard.stripe.com/test/apikeys
#   2. pnpm stripe:login   (once per machine)
#   3. pnpm stripe:listen  (each session — copy whsec_... into STRIPE_WEBHOOK_SECRET, restart API)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:3000/auth/yahoo/callback
AI_API_KEY=
AI_PROVIDER=openai
APP_URL=fantasyleagueos://
WEB_URL=http://localhost:3000
