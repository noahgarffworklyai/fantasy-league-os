{
  "name": "fantasy-league-os",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @flos/api db:generate",
    "db:migrate": "pnpm --filter @flos/api db:migrate",
    "db:studio": "pnpm --filter @flos/api db:studio",
    "stripe:setup": "node scripts/install-stripe-cli.mjs",
    "stripe:login": "node scripts/stripe-login.mjs",
    "stripe:listen": "node scripts/stripe-listen.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-webview": "13.15.0",
      "react-native-safe-area-context": "~5.6.0",
      "react-native-screens": "~4.16.0",
      "react-native-svg": "15.12.1"
    }
  }
}
